{
  "name": "@r3ply/cloudflare-worker",
  "author": "Spencer Van Wessem Scorcelletti",
  "license": "AGPL-3.0-only",
  "private": true,
  "version": "0.0.1",
  "description": "Cloudflare worker for the r3ply commenting system",
  "scripts": {
    "cf:types": "npx wrangler types",
    "build": "pnpm cf:types && wrangler deploy --dry-run --outdir=dist",
    "cf:deploy": "npx wrangler deploy",
    "cf:tail": "npx wrangler tail",
    "dev": "npx wrangler dev",
    "test": "npx vitest run unit",
    "test:watch": "npx vitest unit",
    "test:it": "npx vitest integration run",
    "test:it:watch": "npx vitest integration"
  },
  "dependencies": {
    "@iarna/toml": "^3.0.0",
    "@mail-parser/ts-bindings": "file:../../tools/mail-parser-ts-bindings-0.9.1.tgz",
    "@octokit/app": "^15.1.4",
    "@octokit/core": "^6.1.4",
    "@octokit/rest": "^21.1.1",
    "@octokit/types": "^12.3.0",
    "@r3ply/lib": "workspace:*",
    "@r3ply/schema": "workspace:*",
    "@r3ply/wasm": "workspace:^",
    "@types/node": "^24.2.1",
    "hono": "^4.8.10",
    "mime": "^4.0.6",
    "mimetext": "^3.0.16",
    "octokit": "^4.1.2",
    "oxide.ts": "^1.1.0",
    "typescript-mailbox-parser": "0.0.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.14",
    "typescript": "^5.5.4",
    "vitest": "^4.1.0",
    "wrangler": "^4.42.0"
  },
  "volta": {
    "node": "22.9.0"
  }
}
