{
  "type": "module",
  "name": "@r3ply/cli",
  "version": "0.0.1",
  "description": "CLI for r3ply commenting system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "re": "./dist/index.mjs"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "pretrain": "tsx src/comments/prepare.js",
    "train": "tsx src/comments/train.js",
    "test": "npx vitest run",
    "test:watch": "npx vitest"
  },
  "dependencies": {
    "@exodus/schemasafe": "^1.3.0",
    "@iarna/toml": "^2.2.5",
    "@r3ply/config": "workspace:*",
    "@r3ply/lib": "workspace:*",
    "@r3ply/wasm": "file:../../crates/r3ply-wasm/pkg/r3ply-wasm-0.0.1.tgz",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dayjs": "^1.11.13",
    "fast-glob": "^3.3.3",
    "oxide.ts": "^1.1.0",
    "rita": "^3.1.3"
  },
  "devDependencies": {
    "@types/mock-fs": "^4.13.4",
    "mock-fs": "^5.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.5.4",
    "vitest": "^3.0.8"
  },
  "volta": {
    "node": "20.10.0"
  },
  "author": "Spencer Scorcelletti",
  "license": "MIT"
}
