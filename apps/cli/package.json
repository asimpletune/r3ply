{
  "name": "@r3ply/cli",
  "author": "Spencer Van Wessem Scorcelletti",
  "license": "AGPL-3.0-only",
  "private": false,
  "version": "0.0.1",
  "description": "CLI for the r3ply commenting system",
  "repository": {
    "type": "git",
    "url": "https://github.com/r3ply/r3ply"
  },
  "bugs": {
    "url": "https://github.com/r3ply/r3ply/issues"
  },
  "homepage": "https://r3ply.com",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "re": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "pretrain": "tsx src/comment_generation/prepare.ts",
    "train": "tsx src/comment_generation/train.ts",
    "test": "npx vitest run",
    "test:watch": "npx vitest"
  },
  "dependencies": {
    "@exodus/schemasafe": "^1.3.0",
    "@iarna/toml": "^2.2.5",
    "@r3ply/lib": "workspace:*",
    "@r3ply/schema": "workspace:*",
    "@r3ply/wasm": "workspace:^",
    "@types/prompts": "^2.4.9",
    "chalk": "^5.4.1",
    "cli-highlight": "^2.1.11",
    "commander": "^13.1.0",
    "dayjs": "^1.11.13",
    "fast-glob": "^3.3.3",
    "oxide.ts": "^1.1.0",
    "prompts": "^2.4.2",
    "rita": "^3.1.3",
    "serve-handler": "^6.1.6",
    "typescript-mailbox-parser": "0.0.3"
  },
  "devDependencies": {
    "@types/mock-fs": "^4.13.4",
    "@types/serve-handler": "^6.1.4",
    "mock-fs": "^5.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.5.4",
    "vitest": "^3.2.4"
  },
  "volta": {
    "node": "22.9.0"
  },
  "engines": {
    "node": ">=22"
  }
}
