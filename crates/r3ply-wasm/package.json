{
  "name": "@r3ply/wasm",
  "author": "Spencer Van Wessem Scorcelletti",
  "license": "MIT",
  "private": false,
  "version": "0.0.1",
  "description": "Wasm bindings of useful dependencies for the r3ply commenting system",
  "repository": {
    "type": "git",
    "url": "https://github.com/r3ply/r3ply"
  },
  "bugs": {
    "url": "https://github.com/r3ply/r3ply/issues"
  },
  "homepage": "https://r3ply.com",
  "scripts": {
    "build:cargo": "cargo build",
    "build:node": "wasm-pack build --release --target nodejs --out-name r3ply-wasm-node --no-pack",
    "build:bundler": "wasm-pack build --release --target bundler --out-name r3ply-wasm-bundler --no-pack",
    "build:patch": "cp ./bundler-wasm-patch.js pkg/r3ply-wasm-bundler.js",
    "build:package": "cp ./package.json ./README.md ./LICENSE pkg/",
    "build:wasm": "pnpm build:node && pnpm build:bundler && pnpm build:patch && pnpm build:package",
    "build:all": "pnpm build:cargo && pnpm build:wasm",
    "pack": "wasm-pack pack",
    "test": "cargo test",
    "test:watch": "cargo watch test"
  },
  "files": [
    "README.md",
    "LICENSE",
    "r3ply-wasm-bundler_bg.js",
    "r3ply-wasm-bundler_bg.wasm",
    "r3ply-wasm-bundler_bg.wasm.d.ts",
    "r3ply-wasm-bundler.d.ts",
    "r3ply-wasm-bundler.js",
    "r3ply-wasm-node_bg.wasm",
    "r3ply-wasm-node_bg.wasm.d.ts",
    "r3ply-wasm-node.d.ts",
    "r3ply-wasm-node.js"
  ],
  "types": "./r3ply-wasm-node.d.ts",
  "exports": {
    "node": {
      "import": "./r3ply-wasm-node.js",
      "types": "./r3ply-wasm-node.d.ts",
      "require": "./r3ply-wasm-node.js"
    },
    "default": {
      "import": "./r3ply-wasm-bundler.js",
      "types": "./r3ply-wasm-bundler.d.ts",
      "require": "./r3ply-wasm-bundler.js"
    }
  }
}
