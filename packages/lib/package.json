      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "tsup": "^8.4.0",
    "typescript": "^5.5.4",
