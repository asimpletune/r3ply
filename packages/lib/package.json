    "@mail-parser/ts-bindings": "file:../../tools/mail-parser-ts-bindings-0.9.1.tgz"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@r3ply/schema": "workspace:*",
    "@r3ply/wasm": "workspace:^",
    "dayjs": "^1.11.13",
    "micromatch": "^4.0.8",
    "oxide.ts": "^1.1.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "npx vitest run",
    "test:watch": "npx vitest"
