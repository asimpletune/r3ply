  "license": "AGPL-3.0-only",
  "private": false,
  "version": "0.0.2",
  "description": "The r3ply commenting system library",
  "repository": {
    "type": "git",
    "url": "https://github.com/r3ply/r3ply"
  },
  "bugs": {
    "url": "https://github.com/r3ply/r3ply/issues"
  },
  "homepage": "https://r3ply.com",
  "type": "module",
  "main": "dist/index.js",
