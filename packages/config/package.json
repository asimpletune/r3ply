{
  "type": "module",
  "name": "@r3ply/config",
  "version": "0.0.1",
  "description": "Config schemas and parsers/validators for the r3ply commenting system",
  "main": "dist/index.cjs",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build:generate": "tsx generate.ts",
    "build:compile": "tsup src/generated/index.ts --dts --clean --format esm,cjs",
    "build": "npm run build:generate && npm run build:compile",
    "test": "npx vitest run",
    "test:watch": "npx vitest"
  },
  "dependencies": {
    "@esbuild/darwin-arm64": "^0.25.1",
    "@exodus/schemasafe": "^1.3.0",
    "json-schema-to-ts": "^3.1.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.5.4",
    "vitest": "^3.0.8"
  },
  "volta": {
    "node": "20.10.0"
  },
  "author": "Spencer Scorcelletti",
  "license": "MIT"
}
