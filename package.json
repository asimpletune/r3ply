{
  "name": "r3ply",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "fmt": "prettier --write \"**/*.{js,cjs,ts,mts,jsx,tsx,json,md,toml}\"",
    "build:wasm": "pnpm --filter @r3ply/wasm run build:wasm && pnpm --filter @r3ply/wasm run pack",
    "build:pkgs": "pnpm -r --filter './packages/*' run build",
    "build:apps": "pnpm -r --filter './apps/*' run build",
    "build:all": "pnpm build:wasm && pnpm build:pkgs && pnpm build:apps",
    "test:ts": "vitest run",
    "test:ts:watch": "vitest",
    "test:all": "pnpm -r test"
  },
  "pnpm": {
    "overrides": {}
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "prettier-plugin-toml": "^2.0.2",
    "vitest": "^3.0.8"
  },
  "volta": {
    "node": "20.10.0"
  }
}
