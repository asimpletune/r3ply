{
  "name": "@r3ply/docs",
  "author": "Spencer Van Wessem Scorcelletti",
  "license": "CC-BY-SA-4.0",
  "private": true,
  "version": "0.0.1",
  "description": "The r3ply site and documentation",
  "scripts": {
    "initialize": "git submodule update --init --remote --recursive",
    "copy:schemas": "cp -r ../packages/schema/dist/schemas static/",
    "build": "zola build $BUILD_OPTS && npx @tailwindcss/cli -i ./css/input.css -o ./public/style.css -m",
    "build:cf": "if [ \"$CF_PAGES_BRANCH\" = \"main\" ]; then pnpm build; else BUILD_OPTS=\"--base-url $CF_PAGES_URL\" pnpm build; fi",
    "serve": "zola serve --port 7759 $SERVE_OPTS & npx @tailwindcss/cli  -i ./css/input.css -o ./public/style.css --watch && wait",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "volta": {
    "node": "22.9.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.16",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "tailwindcss": "^4.1.12"
  },
  "dependencies": {
    "fuse.js": "^7.1.0"
  }
}
